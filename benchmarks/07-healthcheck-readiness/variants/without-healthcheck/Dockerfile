# syntax=docker/dockerfile:1
# Generated by tools/dockerfile_wizard.py
# Java 25  |  build-tool: maven

FROM eclipse-temurin:25-jdk@sha256:572fe7b5b3ca8beb3b3aca96a7a88f1f7bc98a3bdffd03784a4568962c1a963a AS build
WORKDIR /app
COPY mvnw pom.xml ./
COPY .mvn ./.mvn
RUN chmod +x mvnw
RUN --mount=type=cache,sharing=locked,target=/root/.m2 \
    ./mvnw -B -q dependency:go-offline
COPY src ./src
RUN --mount=type=cache,sharing=locked,target=/root/.m2 \
    ./mvnw -B -q package -DskipTests

FROM eclipse-temurin:25-jdk@sha256:572fe7b5b3ca8beb3b3aca96a7a88f1f7bc98a3bdffd03784a4568962c1a963a AS app-extract
WORKDIR /app_extracted
COPY --from=build /app/target/*.jar app.jar
RUN java -Djarmode=layertools -jar app.jar extract

FROM eclipse-temurin:25-jdk@sha256:572fe7b5b3ca8beb3b3aca96a7a88f1f7bc98a3bdffd03784a4568962c1a963a AS jre-builder
WORKDIR /app_extracted
COPY --from=build /app/target/*.jar app.jar
RUN java -Djarmode=layertools -jar app.jar extract
RUN jdeps --ignore-missing-deps --recursive --multi-release 25 --print-module-deps \
    --class-path 'dependencies/BOOT-INF/lib/*' app.jar > modules.txt
ARG MUSTHAVE_MODULES="java.base,java.logging,java.sql,java.naming,java.management,java.security.jgss,jdk.crypto.ec,jdk.unsupported"
RUN set -eux; \
    MODULES=$( (tr ',' '\n' < modules.txt; \
        printf '%s\n' "$MUSTHAVE_MODULES" | tr ',' '\n') \
        | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' \
        | grep -v '^$' | sort -u | paste -sd, -); \
    echo "Resolved modules: $MODULES"; \
    jlink --add-modules "$MODULES" \
          --strip-debug --no-man-pages --no-header-files \
          --compress=2 --output /opt/custom-java

FROM debian:bookworm-slim@sha256:d5d3f9c23164ea16f31852f95bd5959aad1c5e854332fe00f7b3a20fcc9f635c AS aot-trainer
COPY --from=jre-builder /opt/custom-java /opt/java
ENV JAVA_HOME=/opt/java
ENV PATH="${JAVA_HOME}/bin:${PATH}"
WORKDIR /app
COPY --from=app-extract /app_extracted/dependencies/ ./
COPY --from=app-extract /app_extracted/snapshot-dependencies/ ./
COPY --from=app-extract /app_extracted/spring-boot-loader/ ./
COPY --from=app-extract /app_extracted/application/ ./
RUN java -XX:AOTCacheOutput=app.aot -Dspring.context.exit=onRefresh org.springframework.boot.loader.launch.JarLauncher; \
    test -f app.aot

FROM debian:bookworm-slim@sha256:d5d3f9c23164ea16f31852f95bd5959aad1c5e854332fe00f7b3a20fcc9f635c
RUN apt-get update && apt-get install -y --no-install-recommends curl passwd && rm -rf /var/lib/apt/lists/*
RUN groupadd --system --gid 1001 javauser && \
    useradd --system --uid 1001 --gid 1001 --no-create-home --shell /usr/sbin/nologin javauser
ENV JAVA_HOME=/opt/java
ENV PATH="${JAVA_HOME}/bin:${PATH}"
RUN install -d -o 1001 -g 1001 -m 755 /app && install -d -o 1001 -g 1001 -m 1777 /tmp
WORKDIR /app
COPY --from=jre-builder /opt/custom-java /opt/java
COPY --from=app-extract --chown=1001:1001 /app_extracted/dependencies/ ./
COPY --from=app-extract --chown=1001:1001 /app_extracted/snapshot-dependencies/ ./
COPY --from=app-extract --chown=1001:1001 /app_extracted/spring-boot-loader/ ./
COPY --from=app-extract --chown=1001:1001 /app_extracted/application/ ./
COPY --from=aot-trainer --chown=1001:1001 /app/app.aot ./app.aot
EXPOSE 8080
EXPOSE 8081
USER 1001
ENTRYPOINT ["java", "-XX:AOTCache=app.aot", "-XX:+UseZGC", "-XX:MaxRAMPercentage=75", "-XX:InitialRAMPercentage=50", "-XX:+ExitOnOutOfMemoryError", "-Djava.io.tmpdir=/tmp", "org.springframework.boot.loader.launch.JarLauncher"]
